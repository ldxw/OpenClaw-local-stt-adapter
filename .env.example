# 服务端口
STT_PORT="8080"

# 模型配置
WHISPER_MODEL="small"
WHISPER_DEVICE="cpu"
WHISPER_COMPUTE_TYPE="int8"
DEFAULT_LANGUAGE="zh"

# 说明页面目录；接口不受影响
DOCS_BASE_PATH=/stt

# 单密钥兼容
API_TOKEN="please_change_me_primary_token"

# 多密钥，逗号分隔
# 建议把主密钥也放进去，方便统一管理
API_TOKENS="please_change_me_primary_token,second_token_here,third_token_here"

# CORS 跨域白名单
# 这里写“浏览器打开页面的域名”
# 如果小龙虾/OpenClaw Web 页面域名是 https://claw.example.com
# 就写这个域名
#
# 如果你还会直接访问 STT 页面自己的域名，也一起写进去
# 例如：
# CORS_ALLOW_ORIGINS="https://claw.example.com,https://stt.example.com"
#
# 临时全部放开可写 *
CORS_ALLOW_ORIGINS="https://claw.example.com,https://stt.example.com"
